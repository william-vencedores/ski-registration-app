PORT=3001
CLIENT_URL=http://localhost:5173

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_to_a_strong_password

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Stripe — get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# Email (nodemailer) — use Gmail App Password or any SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Vencedores Ski <noreply@vencedoreski.com>"
